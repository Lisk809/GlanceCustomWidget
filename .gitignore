# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# ── Gradle 构建产物 ────────────────────────────────────────────────────────────
.gradle/
build/
app/build/
**/build/

# ── 本地配置（不应提交到仓库）────────────────────────────────────────────────
local.properties           # 包含 SDK 路径，每台机器不同
keystore.properties        # 签名配置（绝对不能提交！）
*.jks                      # Keystore 文件（绝对不能提交！）
*.keystore                 # 同上

# ── 签名相关 ──────────────────────────────────────────────────────────────────
app/release.jks            # CI 临时还原的 keystore（理论上 CI 会清理，双重保险）

# ── 捕获文件 ──────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
*.swp

# ── 覆盖率报告 ────────────────────────────────────────────────────────────────
app/coverage.ec
app/coverage/

# ── Android 虚拟设备 ──────────────────────────────────────────────────────────
*.avd/
